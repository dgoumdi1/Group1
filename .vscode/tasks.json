{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Postgres: up",
      "type": "shell",
      "command": "docker",
      "args": [
        "compose",
        "-f",
        "${workspaceFolder}/backend/docker-compose.yml",
        "up",
        "-d",
        "postgres"
      ],
      "problemMatcher": []
    },
    {
      "label": "App: bootRun 8090",
      "type": "shell",
      "command": "${workspaceFolder}/backend/gradlew",
      "args": [
        "-p",
        "${workspaceFolder}/backend",
        ":app:bootRun",
        "--args=--server.port=8090"
      ],
      "problemMatcher": []
    }
  ]
}
